{
  "name": "flexibudget-backend",
  "version": "0.1.0",
  "description": "FlexiBudget API - Adaptive financial planning for irregular income earners",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "server": "nodemon server.js",
    "migrate": "node -e \"require('dotenv').config(); const { sequelize } = require('./models'); const { runMigrations } = require('./utils/migrate'); runMigrations(sequelize).then(() => sequelize.close()).catch((e) => { console.error(e); process.exit(1); });\"",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "budgeting",
    "finance",
    "express",
    "sequelize"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.1.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.0",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "maxWorkers": 1,
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "services/**/*.js",
      "controllers/**/*.js",
      "middleware/**/*.js"
    ]
  }
}
