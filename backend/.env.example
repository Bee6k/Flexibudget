# Server
PORT=5000
NODE_ENV=development

# Database (MySQL 8.0+)
DB_HOST=localhost
DB_PORT=3306
DB_USER=flexiuser
DB_PASSWORD=change_me
DB_NAME=flexibudget

# Auth — generate a strong secret (min 32 chars).
# Example: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=1h

# Frontend origin for CORS (must match Vite dev server)
CLIENT_ORIGIN=http://localhost:5173
