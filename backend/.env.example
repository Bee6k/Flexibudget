# Server
PORT=5000
NODE_ENV=development

# Database (MySQL 8.0+)
DB_HOST=localhost
DB_PORT=3306
DB_USER=flexiuser
DB_PASSWORD=change_me
DB_NAME=flexibudget
# Set DB_SSL=true when connecting to managed MySQL over TLS
# DB_SSL=false

# Auth — generate a strong secret (min 32 chars).
# Example: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
# Keep sessions short; logout bumps token_version to revoke outstanding JWTs
JWT_EXPIRES_IN=1h

# Cookie Secure flag: true | false (defaults to true when NODE_ENV=production)
# COOKIE_SECURE=false

# Set when behind a reverse proxy so rate limits see real client IPs
# TRUST_PROXY=true

# Frontend origin for CORS (comma-separated allowlist; never *)
CLIENT_ORIGIN=http://localhost:5173
